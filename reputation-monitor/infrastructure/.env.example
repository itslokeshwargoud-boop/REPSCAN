# ─── Platform API Keys ──────────────────────────────────────────────────────────

# YouTube Data API v3 (Free tier: 10,000 quota units/day)
# Use YOUTUBE_API_KEYS (comma-separated) to provide multiple keys;
# the collector will automatically rotate to the next key when the daily quota is exhausted.
YOUTUBE_API_KEY=
YOUTUBE_API_KEYS=

# Twitter / X API (Requires Basic Plan ~$100/month)
# Search recent tweets, last 7 days, 450 req/15min.
# Use TWITTER_BEARER_TOKENS (comma-separated) to provide multiple tokens;
# the collector will automatically rotate to the next token when the rate limit is hit.
TWITTER_BEARER_TOKEN=
TWITTER_BEARER_TOKENS=

# Instagram credentials (uses instagrapi unofficial library)
# Provide a dedicated/burner Instagram account for monitoring.
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# ─── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://repuser:reppass@postgres:5432/reputation_db

# ─── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── JWT Authentication ──────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-very-secret-key-change-in-production-minimum-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ─── SMTP Email Alerts ───────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_FROM_EMAIL=

# ─── Telegram Bot Alerts ─────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Application Settings ────────────────────────────────────────────────────────
COLLECTION_INTERVAL_SECONDS=1800
STATS_BROADCAST_INTERVAL_SECONDS=30
MAX_POSTS_PER_COLLECTION=500
SENTIMENT_BATCH_SIZE=32
NEGATIVE_SPIKE_THRESHOLD=40
MIN_CLUSTER_SIZE=3

# CORS (comma-separated origins for production)
CORS_ORIGINS=["http://localhost:3000"]

